{
  "name": "agently-mail-client",
  "version": "0.2.0",
  "description": "Agently Mail Bridge — polls an Agently Mail inbox, routes emails by subject prefix to AgentProc-compliant profiles, and auto-replies",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "agently-mail": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --test tests/test-sender-acl.js tests/test-acl-system.js tests/test-dispatcher-clean.js",
    "test:manual": "node tests/test-html-conversion.js && node tests/test-integration.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "agentproc",
    "email",
    "bridge",
    "agently",
    "qqmail",
    "ai-agent",
    "agent-gateway"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@tencent-qqmail/agently-cli": ">=1.0.0"
  },
  "license": "MIT",
  "author": "jeffkit <bbmyth@gmail.com>",
  "homepage": "https://github.com/jeffkit/agently-mail-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffkit/agently-mail-client.git"
  },
  "bugs": {
    "url": "https://github.com/jeffkit/agently-mail-client/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src/",
    "bin/",
    "profiles/",
    "email-profiles.example.yaml",
    "email-acl.example.yaml",
    "email-schedules.example.yaml"
  ],
  "dependencies": {
    "agentproc": "^0.1.1",
    "js-yaml": "^5.1.0",
    "marked": "^4.3.0",
    "node-cron": "^4.5.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
